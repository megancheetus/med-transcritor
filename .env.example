# OmniNote - Environment Variables (example)
# Copy this file to .env.local and replace placeholders.

# Gemini (server-side only)
GEMINI_API_KEY=<your_gemini_api_key_here>

# Authentication
AUTH_TOKEN_SECRET=<your_auth_token_secret_here>

# PostgreSQL / Supabase
DATABASE_URL=postgresql://postgres.<your-project-ref>:<your_db_password>@aws-0-us-west-2.pooler.supabase.com:6543/postgres
POSTGRES_SSL=true
POSTGRES_SSL_REJECT_UNAUTHORIZED=false
POSTGRES_CA_CERT=

# Jitsi as a Service (JaaS)
JAAS_APP_ID=<your_jaas_app_id_here>
JAAS_KEY_ID=<your_jaas_key_id_here>
JAAS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n<your_private_key_here>\n-----END PRIVATE KEY-----"
JAAS_DOMAIN=8x8.vc

# Upload direto de áudio privado
BLOB_READ_WRITE_TOKEN=<your_blob_read_write_token_here>

# reCAPTCHA
RECAPTCHA_SITE_KEY=<your_recaptcha_site_key_here>
RECAPTCHA_SECRET_KEY=<your_recaptcha_secret_key_here>

# Email (Resend)
RESEND_API_KEY=<your_resend_api_key_here>
EMAIL_FROM=OmniNote <no-reply@notifications.omninote.com.br>

# URL base da aplicação
APP_URL=http://localhost:3000

# Optional (DEV only) - initial local bootstrap users
AUTH_USERS=[{"username":"admin","password":"change_this_password"}]
AUTH_ADMIN_USERNAME=admin
